# Copy this file to .env and fill in values for local development.
# .env is gitignored — never commit actual credentials.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

POSTGRES_RFP_DB=rfp_db
POSTGRES_CARRIER_DB=carrier_db

CONN_RFP_DB=Host=postgres-rfp;Database=rfp_db;Username=postgres;Password=postgres
CONN_CARRIER_DB=Host=postgres-carrier;Database=carrier_db;Username=postgres;Password=postgres
