# Copy this file to .env before running docker compose:
#   cp .env.example .env
#
# .env is gitignored — never commit actual secrets.
# .env.example is committed: values here are safe dev-only defaults, not real credentials.

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_RFP_DB=rfp_db
POSTGRES_CARRIER_DB=carrier_db
CONN_RFP_DB=Host=postgres-rfp;Database=rfp_db;Username=postgres;Password=postgres
CONN_CARRIER_DB=Host=postgres-carrier;Database=carrier_db;Username=postgres;Password=postgres

# ── Redis ──────────────────────────────────────────────────────────────────────
CONN_REDIS=redis:6379

# ── RabbitMQ ───────────────────────────────────────────────────────────────────
RABBITMQ_HOST=rabbitmq
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# ── JWT (freight-gateway signing key — dev stub only) ─────────────────────────
# In production replace with Azure AD B2C / Keycloak; this key is never used outside localhost.
JWT_KEY=dev-only-key-freightflow-32chars!!
JWT_ISSUER=freight-gateway
JWT_AUDIENCE=freight-flow

# ── Internal service endpoints ─────────────────────────────────────────────────
CARRIER_GRPC_ENDPOINT=http://freight-carrier-api:5011
