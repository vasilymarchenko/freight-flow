{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ReverseProxy": {
    "Clusters": {
      "rfp-cluster": {
        "Destinations": {
          "rfp": { "Address": "http://localhost:5000" }
        }
      },
      "carrier-cluster": {
        "Destinations": {
          "carrier": { "Address": "http://localhost:5001" }
        }
      }
    }
  }
}
